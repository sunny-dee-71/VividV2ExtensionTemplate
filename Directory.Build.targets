<?xml version="1.0" encoding="utf-8"?>
<Project>
	<Target Name="CopyToPlugins" AfterTargets="Build" Condition="'$(CI)' != 'TRUE'">
		<Copy
		  SourceFiles="$(TargetPath)"
		  DestinationFiles="$(PluginsPath)\$(TargetName).vivid" />
		<Message Text="Extension copied to vivid extensions folder!" Importance="high"/>
	</Target>
</Project>